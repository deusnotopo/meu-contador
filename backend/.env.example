# =============================================================================
# MEU CONTADOR — Backend Environment Variables
# =============================================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no git!
# =============================================================================

# Application
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# JWT Secret — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=gere-uma-chave-longa-e-aleatoria-aqui

# =============================================================================
# DATABASE (Supabase PostgreSQL)
# Supabase Dashboard → Project Settings → Database
# =============================================================================
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# =============================================================================
# FIREBASE ADMIN SDK (para verificação de tokens Google no login)
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Abra o JSON baixado e copie os campos abaixo:
# =============================================================================
FIREBASE_PROJECT_ID="meucontador-367cf"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-XXXXX@meucontador-367cf.iam.gserviceaccount.com"
# Cole o valor de "private_key" do JSON. Mantenha as \n literais — o código as converte.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBg...\n-----END PRIVATE KEY-----\n"

# =============================================================================
# PLUGGY — Open Finance
# https://dashboard.pluggy.ai → API Keys
# =============================================================================
PLUGGY_CLIENT_ID="seu-client-id"
PLUGGY_CLIENT_SECRET="seu-client-secret"

# =============================================================================
# BRAPI — Dados de Mercado (Ações/FIIs)
# https://brapi.dev → Dashboard → API Key
# =============================================================================
BRAPI_TOKEN="seu-token-brapi"
BRAPI_BASE_URL="https://brapi.dev/api"

# =============================================================================
# WEB PUSH (Notificações)
# Gere com: npx web-push generate-vapid-keys
# =============================================================================
PUBLIC_VAPID_KEY=sua-chave-publica-vapid
PRIVATE_VAPID_KEY=sua-chave-privada-vapid

# =============================================================================
# GOOGLE GEMINI AI
# https://aistudio.google.com/apikey → Create API key
# =============================================================================
GEMINI_API_KEY="AIzaSy..."

# =============================================================================
# OPEN FINANCE WEBHOOK (Pluggy → Backend)
# Segredo compartilhado para validar webhooks da Pluggy
# =============================================================================
OPEN_FINANCE_WEBHOOK_SECRET="segredo-compartilhado-com-pluggy"
# OPEN_FINANCE_WEBHOOK_SIGNING_SECRET="segredo-para-hmac"  # alternativa mais segura
