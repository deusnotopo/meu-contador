generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================================================
// PostgreSQL — supports enums natively.
// String fields kept for backward compat; can be
// migrated to @db.Enum in a future refactor.
// =====================================================

model User {
  id              String      @id @default(uuid())
  email           String      @unique
  name            String?
  passwordHash    String      @default("")
  monthlyIncome   Float?
  financialGoal   String?
  riskProfile     String?
  hasEmergencyFund Boolean    @default(false)
  hasDebts        Boolean    @default(false)
  initialBalance  Float       @default(0)
  isPro           Boolean     @default(false)
  employmentType  String?
  onboardingCompleted Boolean @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  // Business Profile
  businessName    String?
  businessCnpj    String?
  businessSector  String?

  // AI & Behavioral Profiling
  age             Int?
  dependents      Int?
  investmentHorizon String?
  investorProfile  String?    // anxious | stuck | excited | protective
  retirementAge    Int?
  fireTargetIncome Float?

  // Proteção e Compliance
  lgpdConsent      Boolean    @default(false)
  lgpdConsentAt    DateTime?
  insuranceTypes   String?    // JSON: ['life','health','auto'] 
  openFinanceBank  String?    // banco selecionado para Open Finance

  workspaces      Workspace[] @relation("UserWorkspaces")
  currentWorkspaceId String?

  transactions    Transaction[]
  budgets         Budget[]
  goals           SavingsGoal[]
  reminders       BillReminder[]
  investments     Investment[]
  investmentSales InvestmentSale[]
  debts           Debt[]
  bankConnections BankConnection[]
  bankAccounts    BankAccount[]
  pushSubscriptions PushSubscription[]
  sessions        Session[]
  auditLogs       AuditLog[]
  preferences     String      @default("{\"theme\":\"dark\",\"language\":\"pt\",\"privacyMode\":false}")

  // Gamification and Emotional Data
  gamificationData String?    // JSON: { level, achievements, streaks, etc. }
  emotionalData    String?    // JSON: array of emotional entries

  @@index([deletedAt])
}

model Session {
  id                String   @id @default(uuid())
  userId            String
  refreshTokenHash  String   @unique
  csrfToken         String
  userAgent         String?
  ipAddress         String?
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, revokedAt])
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  ownerId     String
  members     User[]   @relation("UserWorkspaces")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]
  invoices     Invoice[]
  invites      WorkspaceInvite[]
}

model WorkspaceInvite {
  id          String   @id @default(uuid())
  email       String
  role        String   @default("viewer")
  token       String   @unique
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  
  @@index([workspaceId, email])
}

model Transaction {
  id                 String              @id @default(uuid())
  type               String
  description        String
  amount             Float
  category           String
  date               DateTime
  paymentMethod      String?
  notes              String?
  recurring          Boolean             @default(false)
  recurrenceInterval String?
  scope              String
  classification     String?
  currency           String              @default("BRL")
  originalAmount     Float?
  exchangeRate       Float?
  receiptUrl         String?
  mood               String?
  motivation         String?
  fitid              String?

  userId             String
  user               User     @relation(fields: [userId], references: [id])
  workspaceId        String?
  workspace          Workspace? @relation(fields: [workspaceId], references: [id])

  // Open Finance Integration
  bankAccountId      String?
  bankAccount        BankAccount? @relation(fields: [bankAccountId], references: [id])
  pluggyTransactionId String? @unique

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?
  dataReliability    String   @default("REAL")

  @@unique([userId, fitid], name: "unique_user_fitid")
  @@unique([userId, pluggyTransactionId], name: "unique_user_pluggy")
  @@index([userId, date])
  @@index([userId, scope, date])
  @@index([userId, type, date])
  @@index([userId, category, date])
  @@index([bankAccountId, date])
  @@index([deletedAt])
}

model BankConnection {
  id              String           @id @default(uuid())
  pluggyItemId    String           @unique
  status          String           @default("UPDATING")
  lastSyncAt      DateTime?
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  accounts        BankAccount[]

  @@index([userId, updatedAt])
  @@index([deletedAt])
}

model BankAccount {
  id              String          @id @default(uuid())
  pluggyAccountId String          @unique
  name            String
  balance         Float
  currencyCode    String          @default("BRL")
  type            String
  subtype         String?
  bankName        String?
  bankImageUrl    String?
  connectionId    String
  connection      BankConnection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  // Reconciliation fields
  calculatedBalance Float?      // Sum of user transactions
  lastReconciledAt  DateTime?   // Last time reconciliation was performed
  reconciliationStatus String? // MATCHING, DISCREPANCY, ERROR
  discrepancyAmount Float?      // bank balance - calculated balance

  transactions      Transaction[]

  @@index([userId, balance])
}


model Budget {
  id        String   @id @default(uuid())
  category  String
  limit     Float
  spent     Float    @default(0)
  month     String   // YYYY-MM
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([userId, month])
  @@unique([userId, category, month])
  @@index([deletedAt])
}

model SavingsGoal {
  id            String   @id @default(uuid())
  name          String
  targetAmount  Float
  currentAmount Float    @default(0)
  deadline      DateTime
  icon          String?
  color         String?
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@index([userId, deadline])
  @@index([userId, targetAmount])
  @@index([deletedAt])
}

model BillReminder {
  id        String       @id @default(uuid())
  name      String
  amount    Float
  dueDate   DateTime
  category  String
  isPaid    Boolean      @default(false)
  recurring String       @default("ONCE")
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  @@index([userId, dueDate, isPaid])
  @@index([deletedAt])
}

model Invoice {
  id          String        @id @default(uuid())
  number      String
  client      String
  amount      Float
  dueDate     DateTime
  status      String        @default("PENDING")
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@index([workspaceId, status])
  @@index([workspaceId, dueDate])
  @@index([deletedAt])
  @@unique([workspaceId, number], name: "unique_workspace_invoice")
}

model Investment {
  id                String          @id @default(uuid())
  name              String
  ticker            String
  type              String
  amount            Float
  averagePrice      Float
  currentPrice      Float
  currency          String          @default("BRL")
  sector            String?
  targetAllocation  Float?
  lastUpdate        DateTime        @default(now())
  userId            String
  dataReliability   String          @default("REAL")
  user              User            @relation(fields: [userId], references: [id])
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  dividends    Dividend[]
  sales        InvestmentSale[]

  @@index([userId, ticker])
  @@index([userId, lastUpdate])
  @@index([deletedAt])
  @@unique([userId, ticker, type], name: "unique_user_investment")
}

model Dividend {
  id           String       @id @default(uuid())
  investmentId String
  investment   Investment   @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  amount       Float
  date         DateTime
  type         String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([investmentId, date])
  @@unique([investmentId, type, date])
}

model InvestmentSale {
  id           String   @id @default(uuid())
  investmentId String
  investment   Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  ticker       String
  amount       Float
  price        Float
  totalValue   Float
  date         DateTime
  currency     String   @default("BRL")
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, date])
  @@index([investmentId, date])
}

model Debt {
  id           String       @id @default(uuid())
  name         String
  balance      Float
  interestRate Float
  minPayment   Float
  dueDate      DateTime?
  category     String
  userId       String
  dataReliability String   @default("REAL")
  user         User         @relation(fields: [userId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  @@index([userId, dueDate])
  @@index([userId, category])
  @@index([userId, balance])
  @@index([deletedAt])
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  resource    String
  resourceId  String?
  metadata    String?
  piiRedacted Boolean  @default(true)
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([resource, resourceId, createdAt])
  @@index([expiresAt])
}